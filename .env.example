# MatchMaker bot — environment template. Copy this file to .env and fill in the required
# values below. Everything else (roles, categories, channels, your Yunite token) is configured
# per-server by running /matchmaker-setup as an admin after inviting the bot — no more manual
# ID-pasting into .env for a new server.

# ── Discord app (required) ──────────────────────────────────────────────────
DISCORD_TOKEN=
CLIENT_ID=

# ── Database (required) ─────────────────────────────────────────────────────
# MongoDB connection string — required. Per-guild config (roles/channels/categories/Yunite
# tokens) is Mongo-only; queue/party/match data falls back to a local data.json file if this
# is unreachable, but guild config has no offline equivalent.
MONGODB_URI=

# ── Integrations (optional) ─────────────────────────────────────────────────
# Fallback Yunite API token, used only for a guild that hasn't set its own via
# /matchmaker-setup (in practice, just your own dev/test server). Leave blank otherwise —
# each server's admin supplies their own token when they run /matchmaker-setup.
YUNITE_TOKEN=

# ── Epic account linking (optional — falls back to Yunite-only until these are set) ────────
# Primary path for linking a player's Epic account (epic-oauth.js), replacing Yunite as the
# default. Yunite (YUNITE_TOKEN above / a guild's own token) stays available as a fallback for
# players who haven't linked via Epic OAuth yet, or if a token exchange fails.
# Client ID/secret from the Epic Games Developer Portal (dev.epicgames.com) for an app with the
# "basic_profile" scope enabled.
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
# Must exactly match the redirect URI registered for your app on the Epic Games Developer Portal,
# and point at this same webhook server's /epic-callback route, e.g.
# https://<your-domain>/epic-callback. Uses the same PORT/public-exposure setup as
# STRIPE_WEBHOOK_SECRET below — no separate server or port.
EPIC_REDIRECT_URI=

# ── Payments (optional — subscriptions are disabled until these are set) ───────────────────
# Stripe secret key (test or live), from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Publishable key — not used server-side today (this bot has no web frontend), kept here for
# completeness/future use.
STRIPE_PUBLISHABLE_KEY=
# Signing secret for the webhook endpoint (webhook-server.js) — from the Stripe Dashboard's
# Webhooks page, or `stripe listen`'s output while testing locally.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_...) for the Monthly (£2.99) and Yearly (£29.99) products — create
# these in the Stripe Dashboard ahead of time. No trial price — the free trial is bot-managed
# (access.js), never touches Stripe at all.
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
# Where Stripe redirects the browser after Checkout succeeds/is cancelled. This bot has no web
# frontend — any valid https:// page works; a Discord invite link back to your server is a
# reasonable default.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# Port the Stripe webhook HTTP server (webhook-server.js) listens on. You must separately expose
# this port publicly (reverse proxy or a tunnel like ngrok/Cloudflare Tunnel) and register
# https://<your-domain>/stripe/webhook in the Stripe Dashboard — neither step can be automated
# here.
PORT=3000

# ── Legacy single-guild migration (do not set for a new install) ───────────
# These only matter if you're upgrading a bot instance that ran the original single-server
# version of MatchMaker (env-var-configured roles/channels/categories for exactly one guild).
# If set, GUILD_ID's existing role/channel/category IDs below are copied into that guild's
# Mongo config once, automatically, on first startup after upgrading — then these variables
# can be deleted. A brand-new install should leave this whole section blank.
GUILD_ID=
ROLE_CONSOLE=
ROLE_PC=
ROLE_MOBILE=
ROLE_EU=
ROLE_ME=
ROLE_NAC=
ROLE_IGL=
ROLE_FRAGGER=
MOD_ROLE_ID=
CATEGORY_EU=
CATEGORY_NAC=
CATEGORY_ME=
GET_ROLES_CHANNEL_ID=
FORM_PARTY_CHANNEL_ID=
HOWTO_CHANNEL_ID=
MATCH_CATEGORY_ID=
