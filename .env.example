# MatchMaker bot — environment template. Copy this file to .env and fill in every value
# below for your server. See README/setup docs for how to obtain each ID/token.

# ── Discord app ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# ── Region / platform roles (role IDs from Server Settings > Roles) ────────────
ROLE_CONSOLE=
ROLE_PC=
ROLE_MOBILE=
ROLE_EU=
ROLE_ME=
ROLE_NAC=
ROLE_IGL=
ROLE_FRAGGER=

# ── Moderation ───────────────────────────────────────────────────────────────
MOD_ROLE_ID=

# ── Tournament channel categories (per region) ──────────────────────────────
CATEGORY_EU=
CATEGORY_NAC=
CATEGORY_ME=

# ── Fixed channel IDs ────────────────────────────────────────────────────────
GET_ROLES_CHANNEL_ID=
FORM_PARTY_CHANNEL_ID=
HOWTO_CHANNEL_ID=
CREATIVE_6S_CHANNEL_ID=
CREATIVE_8S_CHANNEL_ID=

# Auto-created if left blank — set only to reuse an existing category.
MATCH_CATEGORY_ID=

# ── Integrations ─────────────────────────────────────────────────────────────
YUNITE_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string. If left blank or unreachable, the bot falls back to a
# local data.json file for persistence.
MONGODB_URI=
